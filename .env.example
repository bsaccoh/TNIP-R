# ─── TNIP-R root environment ───────────────────────────────────────────────
# Copy to .env and adjust. Consumed by docker-compose.

# MySQL
MYSQL_ROOT_PASSWORD=rootpass_change_me
MYSQL_DATABASE=tnipr
MYSQL_USER=tnipr
MYSQL_PASSWORD=tnipr_change_me
MYSQL_PORT=3306

# Backend
BACKEND_PORT=4000
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_string
JWT_ACCESS_TTL=900            # 15 min (seconds)
JWT_REFRESH_TTL=604800        # 7 days (seconds)
LOG_LEVEL=info
# Max upload size in MB for PM files
UPLOAD_MAX_MB=100

# AI module — heuristic by default. Set AI_PROVIDER=anthropic + key to enable real LLM.
AI_PROVIDER=heuristic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Frontend
FRONTEND_PORT=8080
# URL the browser uses to reach the API (through nginx)
VITE_API_BASE_URL=/api/v1
